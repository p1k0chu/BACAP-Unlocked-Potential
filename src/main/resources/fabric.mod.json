{
  "schemaVersion": 1,
  "id": "bacapup",
  "version": "${version}",
  "name": "BAC Unlocked Potential",
  "description": "BACAP addon that adds more advancements that are now possible with modding",
  "authors": [
    "p1k0chu"
  ],
  "contact": {
  },
  "license": "MIT",
  "icon": "assets/bacapup/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "io.github.p1k0chu.bacapup.Main"
      }
    ],
    "fabric-datagen": [
      {
        "adapter": "kotlin",
        "value": "io.github.p1k0chu.bacapup.DatagenMain"
      }
    ]
  },
  "mixins": [
    "bacapup.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "~26.2-alpha.6",
    "java": ">=25",
    "fabric-language-kotlin": ">=1.13.9+kotlin.2.3.10",
    "fabric-api": ">=0.148.1+26.2"
  }
}
