{
  "schemaVersion": 1,
  "id": "bacapup",
  "version": "${version}",
  "name": "BAC Unlocked Potential",
  "description": "BACAP addon that adds more advancements that are now possible with modding",
  "authors": [
    "p1k0chu"
  ],
  "contact": {
  },
  "license": "MIT",
  "icon": "assets/bac-unlocked-potential/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "com.github.p1k0chu.bacup.Main"
      }
    ],
    "fabric-datagen": [
      {
        "adapter": "kotlin",
        "value": "com.github.p1k0chu.bacup.DatagenMain"
      }
    ]
  },
  "mixins": [
    "bacapup.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "1.21.11",
    "java": ">=25",
    "fabric-language-kotlin": ">=1.13.7+kotlin.2.2.21",
    "fabric-api": ">=0.139.4+1.21.11"
  }
}
